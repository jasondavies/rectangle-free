GTOOLSO=${NAUTYO} gtnauty.o nautinv.o gtools.o

LNAUTYO=nauty.lo nautil.lo nausparse.lo naugraph.lo schreier.lo naurng.lo
LNAUTY1O=nauty1.lo nautil1.lo nausparse.lo naugraph1.lo schreier.lo naurng.lo
